POSTGRES_DB=callquanta
POSTGRES_USER=callquanta
POSTGRES_PASSWORD=callquanta
DATABASE_URL=postgresql+psycopg://callquanta:callquanta@postgres:5432/callquanta
REDIS_URL=redis://redis:6379/0
API_PORT=8000
WEB_PORT=3000
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_MODEL=llama3.1:8b

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

STT_MODE=placeholder
FASTER_WHISPER_MODEL=base
FASTER_WHISPER_DEVICE=cpu
FASTER_WHISPER_COMPUTE_TYPE=int8

QA_MODE=placeholder
QA_QUEUE=qa_jobs
LLM_PROVIDER_CONFIG_SOURCE=db_or_env
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=http://ollama:11434/v1
LLM_MODEL=qwen2.5:1.5b
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=180
OLLAMA_KEEP_ALIVE=-1

# App environment and built-in authentication
APP_ENV=development
REQUIRE_AUTH=true
ADMIN_EMAIL=
ADMIN_PASSWORD=
SESSION_SECRET=

# Retention settings; leave empty to keep forever
RETENTION_AUDIO_DAYS=
RETENTION_TRANSCRIPTS_DAYS=
RETENTION_QA_REVIEWS_DAYS=
RETENTION_INGESTION_EVENTS_DAYS=

# Worker status heartbeat cadence
WORKER_HEARTBEAT_SECONDS=30
