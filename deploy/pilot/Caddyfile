:8080 {
  encode gzip zstd

  @apiHealth path /health
  reverse_proxy @apiHealth api:8000

  handle_path /api/* {
    reverse_proxy api:8000
  }

  @apiBackend {
    not header Accept *text/html*
    path /auth/* /calls* /dashboard* /settings* /system* /integrations* /qa-reviews* /exports* /feedback* /pilot-feedback* /scorecards* /jobs* /qa-feedback*
  }
  reverse_proxy @apiBackend api:8000

  handle {
    reverse_proxy web:3000
  }
}
