APP_ENV=pilot
REQUIRE_AUTH=true
SESSION_SECRET=change-me-random-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin-password-change-me
PUBLIC_APP_URL=
APP_BANNER_TEXT=
APP_BANNER_VARIANT=info

# Buyer-facing pilots must use an explicitly configured real provider mode.
# Placeholder modes generate synthetic output and are for tests/local development only.
STT_MODE=faster_whisper
QA_MODE=openai_compatible
LLM_PROVIDER_CONFIG_SOURCE=db_or_env
LLM_API_KEY=

# Global analyzed-call limit for this single deployment. 0 disables the limit.
DEMO_CALL_LIMIT=50

RETENTION_AUDIO_DAYS=7
RETENTION_TRANSCRIPTS_DAYS=14
RETENTION_QA_REVIEWS_DAYS=30
RETENTION_INGESTION_EVENTS_DAYS=14

MAX_UPLOAD_BYTES_PER_FILE=104857600
MAX_BULK_UPLOAD_BYTES=524288000
