APP_ENV=pilot
REQUIRE_AUTH=true
SESSION_SECRET=change-me-random-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin-password-change-me
PUBLIC_APP_URL=
APP_BANNER_TEXT=Pilot environment. Use only approved test recordings.
APP_BANNER_VARIANT=warning

RETENTION_AUDIO_DAYS=7
RETENTION_TRANSCRIPTS_DAYS=14
RETENTION_QA_REVIEWS_DAYS=30
RETENTION_INGESTION_EVENTS_DAYS=14

MAX_UPLOAD_BYTES_PER_FILE=104857600
MAX_BULK_UPLOAD_BYTES=524288000
