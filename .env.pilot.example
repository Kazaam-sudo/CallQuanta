# Public HTTPS pilots use production security semantics so session cookies are Secure.
APP_ENV=production
REQUIRE_AUTH=true
SESSION_SECRET=replace-with-at-least-32-random-characters
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-unique-password-2026
PUBLIC_APP_URL=https://demo.example.com
CORS_ORIGINS=https://demo.example.com
APP_BANNER_TEXT=
APP_BANNER_VARIANT=info

# Buyer-facing pilots must use an explicitly configured real provider mode.
# Placeholder modes generate synthetic output and are for tests/local development only.
STT_MODE=faster_whisper
QA_MODE=openai_compatible
ALLOW_PLACEHOLDER_AI=false
LLM_PROVIDER_CONFIG_SOURCE=db_or_env
LLM_API_KEY=

# Global analyzed-call limit for this single deployment. 0 disables the limit.
DEMO_CALL_LIMIT=50

# Keep private/local recording targets blocked. For a private PBX, add only its
# exact hostname to RECORDING_DOWNLOAD_ALLOWED_HOSTS.
RECORDING_DOWNLOAD_ALLOW_PRIVATE_HOSTS=false
RECORDING_DOWNLOAD_ALLOWED_HOSTS=
RECORDING_DOWNLOAD_CONNECT_TIMEOUT_SECONDS=10
RECORDING_DOWNLOAD_TIMEOUT_SECONDS=120
RECORDING_DOWNLOAD_MAX_REDIRECTS=5

RETENTION_AUDIO_DAYS=7
RETENTION_TRANSCRIPTS_DAYS=14
RETENTION_QA_REVIEWS_DAYS=30
RETENTION_INGESTION_EVENTS_DAYS=14

MAX_UPLOAD_BYTES_PER_FILE=104857600
MAX_BULK_UPLOAD_BYTES=524288000
